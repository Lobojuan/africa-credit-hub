# =============================================================================
# Pan-African Credit Registry (CDH v2.5) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the application to run.
# Lines marked [OPTIONAL] have sensible defaults and can be omitted.
# =============================================================================

# --- Core / Required ---

# PostgreSQL connection string [REQUIRED]
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session cookies — use a long random string [REQUIRED]
SESSION_SECRET=change-me-to-a-random-string

# AES-256 key for encrypting PII fields (national IDs, dates of birth, etc.) [REQUIRED]
PII_ENCRYPTION_KEY=

# Salt used alongside the encryption key for key derivation [REQUIRED]
PII_ENCRYPTION_SALT=

# Public base URL of the deployed application (e.g. https://yourdomain.com) [REQUIRED in production]
CANONICAL_URL=

# --- Authentication (OAuth / SSO) ---

# Google OAuth 2.0 credentials [OPTIONAL — enables Google login]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Azure AD OAuth credentials [OPTIONAL — enables Microsoft SSO]
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Azure AD tenant ID; defaults to "common" for multi-tenant [OPTIONAL]
MICROSOFT_TENANT_ID=common

# SAML SSO configuration [OPTIONAL — enables SAML-based enterprise login]
SAML_IDP_ENTRY_POINT=
SAML_IDP_CERT=
# SP entity ID sent to the IdP; defaults to "pan-african-credit-registry" [OPTIONAL]
SAML_ISSUER=pan-african-credit-registry

# --- Email ---

# SendGrid API key for transactional email [OPTIONAL — alternative to SMTP]
SENDGRID_API_KEY=

# SMTP settings for email delivery [OPTIONAL — alternative to SendGrid]
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address for outgoing emails [OPTIONAL — defaults to PLATFORM_SUPPORT_EMAIL]
SMTP_FROM=

# Email address that receives new-registration notifications [OPTIONAL]
REGISTRATION_NOTIFY_EMAIL=
# Admin notification email [OPTIONAL]
ADMIN_EMAIL=

# --- SMS ---

# Twilio credentials for SMS delivery [OPTIONAL — enables Twilio SMS]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Africa's Talking credentials for SMS delivery [OPTIONAL — enables AT SMS]
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# Set to "true" to use Africa's Talking sandbox [OPTIONAL]
AT_SANDBOX=false

# --- Payments ---

# Stripe secret key for billing and subscriptions [OPTIONAL — enables Stripe payments]
STRIPE_SECRET_KEY=
# Stripe publishable key for client-side checkout [OPTIONAL — required if STRIPE_SECRET_KEY is set]
STRIPE_PUBLISHABLE_KEY=
# Stripe webhook signing secret for verifying incoming webhooks [OPTIONAL — required if using Stripe webhooks]
STRIPE_WEBHOOK_SECRET=

# --- Security ---

# Dedicated JWT secret for external API tokens [REQUIRED in production]
EXTERNAL_API_JWT_SECRET=
# HMAC secret for hashing API keys [OPTIONAL — falls back to SESSION_SECRET]
API_KEY_HMAC_SECRET=
# Password used when seeding admin accounts [OPTIONAL — auto-generates random if unset]
SEED_ADMIN_PASSWORD=

# --- Backup S3 Upload ---

# S3-compatible bucket for offsite backup storage [OPTIONAL — falls back to local disk only]
BACKUP_S3_BUCKET=
# S3 region [OPTIONAL — default: us-east-1]
BACKUP_S3_REGION=us-east-1
# AWS credentials for S3 backup upload [OPTIONAL — required if BACKUP_S3_BUCKET is set]
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- AI ---

# OpenAI API key [OPTIONAL — auto-provisioned by Replit AI Integrations if not set]
OPENAI_API_KEY=

# These are auto-provisioned by Replit AI Integrations — do not set manually
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# --- Identity Verification ---

# Smile Identity [OPTIONAL — enables biometric & document verification]
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=

# ComplyAdvantage [OPTIONAL — enables AML / sanctions screening]
COMPLY_ADVANTAGE_API_KEY=

# --- Bureau Integrations ---

# XDS Ghana Credit Bureau [OPTIONAL]
XDS_GHANA_API_URL=
XDS_GHANA_API_KEY=

# --- Asset Registries ---

# Ghana DVLA (vehicle registry) [OPTIONAL]
GHANA_DVLA_API_URL=
GHANA_DVLA_API_KEY=
# South Africa NATIS (vehicle registry) [OPTIONAL]
SA_NATIS_API_URL=
SA_NATIS_API_KEY=
# Ghana Lands Commission [OPTIONAL]
GHANA_LANDS_API_URL=
GHANA_LANDS_API_KEY=
# Kenya NTSA (vehicle registry) [OPTIONAL]
KENYA_NTSA_API_URL=
KENYA_NTSA_API_KEY=
# Nigeria FRSC (vehicle registry) [OPTIONAL]
NIGERIA_FRSC_API_URL=
NIGERIA_FRSC_API_KEY=
# Uganda URSB (business & asset registry) [OPTIONAL]
UGANDA_URSB_API_URL=
UGANDA_URSB_API_KEY=
# Ethiopia MVAA (vehicle registry) [OPTIONAL]
ETHIOPIA_MVAA_API_URL=
ETHIOPIA_MVAA_API_KEY=

# --- Platform Branding ---

# Support email shown in UI, PDFs, and AI responses [OPTIONAL — default: support@africacredithub.com]
PLATFORM_SUPPORT_EMAIL=support@africacredithub.com
# Contact phone number shown in platform materials [OPTIONAL — default: empty]
PLATFORM_CONTACT_PHONE=
# Company name used in branding, PDFs, and copyright [OPTIONAL — default: Africa Credit Hub]
PLATFORM_COMPANY_NAME=Africa Credit Hub
# Admin display name [OPTIONAL]
PLATFORM_ADMIN_NAME=
# Admin email address shown in platform materials [OPTIONAL]
PLATFORM_ADMIN_EMAIL=
# Admin professional title shown in legal and footer sections [OPTIONAL]
PLATFORM_ADMIN_TITLE=
# CTO display name [OPTIONAL]
PLATFORM_CTO_NAME=
# CTO email address [OPTIONAL]
PLATFORM_CTO_EMAIL=
# Jurisdiction / country name shown in legal sections [OPTIONAL]
PLATFORM_COUNTRY=
# Canonical registry reference number shown in IP/legal notices [OPTIONAL]
PLATFORM_REGISTRY_REF=

# --- Frontend (Vite) ---
# Mirror of platform identity vars exposed to the browser (must be prefixed VITE_)
VITE_PLATFORM_COMPANY_NAME=Africa Credit Hub
VITE_PLATFORM_ADMIN_NAME=
VITE_PLATFORM_REGISTRY_REF=

# --- Platform Control Panel ---

# Password that gates all /api/platform-control/* routes [REQUIRED in production]
# Must be set to a strong, unique value — without it the platform control panel is inaccessible
MASTER_CONTROL_PASSWORD=

# --- Financial Parameters ---

# Default NPL rate for traditional lending benchmark [OPTIONAL — default: 12.5]
PLATFORM_TRADITIONAL_NPL=12.5
# Cost per credit report in platform currency [OPTIONAL — default: 2.50]
PLATFORM_COST_PER_REPORT=2.50
# Revenue per credit report in platform currency [OPTIONAL — default: 8.75]
PLATFORM_REVENUE_PER_REPORT=8.75

# --- Runtime ---

# Port the server listens on [OPTIONAL — default: 5000]
PORT=5000
# Set to "true" to run seed scripts on startup [OPTIONAL — default: false]
RUN_SEED=false
# Set to "true" to enable production hardening (error redaction, etc.) [OPTIONAL]
PRODUCTION_MODE=false
# Node environment [OPTIONAL — set automatically by dev-server.sh]
# NODE_ENV=development
