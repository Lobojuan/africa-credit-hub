modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["chromium", "nss", "at-spi2-atk", "cups", "libdrm", "mesa", "alsa-lib", "pango", "cairo", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXrandr", "xorg.libxcb", "xorg.libXfixes", "dbus", "glib", "gtk3", "expat", "libxkbcommon"]

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash dev-server.sh"
waitForPort = 5000

[agent]
integrations = ["stripe:1.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.gmail.com"
SMTP_USER = "uffe.carlson@gmail.com"
SMTP_FROM = "uffe.carlson@gmail.com"

[userenv.development]

[userenv.production]
CANONICAL_URL = "https://africacredithub.com"
PII_ENCRYPTION_KEY = "c5df17643e5c98e16cc9db0143f888fd3896368573b81ff3c7a4f2cf57176fda"
PII_ENCRYPTION_SALT = "78be51edb14d23779ea0c8618452e17d"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80
