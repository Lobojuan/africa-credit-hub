modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["chromium", "nss", "at-spi2-atk", "cups", "libdrm", "mesa", "alsa-lib", "pango", "cairo", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXrandr", "xorg.libxcb", "xorg.libXfixes", "dbus", "glib", "gtk3", "expat", "libxkbcommon"]

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash dev-server.sh"
waitForPort = 5000

[agent]
integrations = ["stripe:1.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0", "github:1.0.0"]

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.gmail.com"
SMTP_USER = "uffe.carlson@gmail.com"
SMTP_FROM = "uffe.carlson@gmail.com"

[userenv.development]
GHANA_DVLA_API_URL = "http://localhost:5000/api/registry-sandbox/ghana_dvla"
REGISTRY_SANDBOX_KEY_GHANA_DVLA = "sbx-ghana-dvla-2025"
SA_NATIS_API_URL = "http://localhost:5000/api/registry-sandbox/sa_natis"
REGISTRY_SANDBOX_KEY_SA_NATIS = "sbx-sa-natis-2025"
GHANA_LANDS_API_URL = "http://localhost:5000/api/registry-sandbox/ghana_lands"
REGISTRY_SANDBOX_KEY_GHANA_LANDS = "sbx-ghana-lands-2025"
KENYA_NTSA_API_URL = "http://localhost:5000/api/registry-sandbox/kenya_ntsa"
REGISTRY_SANDBOX_KEY_KENYA_NTSA = "sbx-kenya-ntsa-2025"
NIGERIA_FRSC_API_URL = "http://localhost:5000/api/registry-sandbox/nigeria_frsc"
REGISTRY_SANDBOX_KEY_NIGERIA_FRSC = "sbx-nigeria-frsc-2025"
UGANDA_URSB_API_URL = "http://localhost:5000/api/registry-sandbox/uganda_ursb_motor"
REGISTRY_SANDBOX_KEY_UGANDA_URSB_MOTOR = "sbx-uganda-ursb-2025"
ETHIOPIA_MVAA_API_URL = "http://localhost:5000/api/registry-sandbox/ethiopia_motor"
REGISTRY_SANDBOX_KEY_ETHIOPIA_MOTOR = "sbx-ethiopia-mvaa-2025"
GHANA_DVLA_API_KEY = "sbx-ghana-dvla-2025"
SA_NATIS_API_KEY = "sbx-sa-natis-2025"
GHANA_LANDS_API_KEY = "sbx-ghana-lands-2025"
KENYA_NTSA_API_KEY = "sbx-kenya-ntsa-2025"
NIGERIA_FRSC_API_KEY = "sbx-nigeria-frsc-2025"
UGANDA_URSB_API_KEY = "sbx-uganda-ursb-2025"
ETHIOPIA_MVAA_API_KEY = "sbx-ethiopia-mvaa-2025"

[userenv.production]
CANONICAL_URL = "https://africacredithub.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80
